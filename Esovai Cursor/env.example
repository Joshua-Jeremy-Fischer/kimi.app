# ── PFLICHT — Server startet ohne diese Werte NICHT ──────
ALLOWED_TOKEN=                        # openssl rand -base64 32
FRONTEND_ORIGIN=https://kamikimi.esovai.tech

# ── OPTIONAL — Provider ────────────────────────────────────
PORT=3010
DEFAULT_PROVIDER=ollama               # "ollama" | "opencode-go" | "nvidia"

# ollama (default, self-hosted)
OLLAMA_MODEL=llama3.1:8b

# Job-Crawler: nur für llmFilter (JA/NEIN). Leer = gleiches Modell wie OLLAMA_MODEL.
# Empfehlung: kleines lokales Modell (z. B. llama3.1:8b), nicht kimi-k2.5:cloud.
JOB_CRAWLER_MODEL=

# nvidia (cloud fallback — braucht API-Key)
NVIDIA_API_KEY=nvapi-DEIN_KEY_HIER
NVIDIA_MODEL=moonshotai/kimi-k2-instruct-0905

# opencode-go (Mitglied-Option — braucht API-Key)
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://api.opencode.ai/v1
OPENCODE_MODEL=kimi-k2.5

# ── OPTIONAL — Auth & Chat-Persistenz ─────────────────────
JWT_SECRET=                           # openssl rand -base64 32 — aktiviert Login & Chat-Sync
GITHUB_CLIENT_ID=                     # GitHub OAuth App Client-ID
GITHUB_CLIENT_SECRET=                 # GitHub OAuth App Client-Secret
DB_PATH=/data/kimi.db                 # SQLite-Pfad (im Docker-Volume)

# ── OPTIONAL — Eso-Bot (Tool-Runner in separatem Container) ───
# Damit die UI/Agent-Tools "wie OpenClaw" iterativ arbeiten können, aber isoliert.
AGENT_BASE_URL=http://eso-bot:3020
ESO_BOT_TOKEN=                        # openssl rand -base64 32
ALLOW_SHELL=false
ALLOW_WEB=true
ALLOW_FILES=true
ALLOW_GIT=false

# ── LangGraph Multi-Agent Service ─────────────────────────
# Interner URL — wird vom backend als Proxy-Ziel genutzt
LANGCHAIN_AGENT_URL=http://langchain-agent:8001
# Wie oft der Fixer-Agent QA-Fehler korrigieren darf bevor abgebrochen wird
MAX_FIX_ITERATIONS=3
# ESO_BOT_TOKEN (oben gesetzt) wird von langchain-agent mitgenutzt — kein separater Key nötig

# ── Lokal (ohne Docker) ─────────────────────────────────
# In backend/: npm install && npm run fim:gen
# Umgebungsvariablen setzen (PowerShell: $env:KEY="…") oder .env per Tool laden — Node lädt .env nicht von selbst.
# Ollama vom Host: DEFAULT_PROVIDER=ollama und OLLAMA baseURL ggf. auf http://127.0.0.1:11434 anpassen.
