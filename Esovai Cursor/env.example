# ── PFLICHT — Server startet ohne diese Werte NICHT ──────
NVIDIA_API_KEY=nvapi-DEIN_KEY_HIER   # Nur bei LLM_PROVIDER=nvidia erforderlich
ALLOWED_TOKEN=                        # openssl rand -base64 32
# Öffentliche Origin (Tunnel MCP) — exakt so, wie der Browser sie sieht
FRONTEND_ORIGIN=https://kamikimi.esovai.tech

# ── OPTIONAL ──────────────────────────────────────────────
PORT=3010
LLM_PROVIDER=nvidia                        # "nvidia" | "ollama"
NVIDIA_MODEL=moonshotai/kimi-k2-instruct-0905
OLLAMA_MODEL=llama3.1:8b

# ── Lokal (ohne Docker) ─────────────────────────────────
# In backend/: npm install && npm run fim:gen
# Umgebungsvariablen setzen (PowerShell: $env:KEY="…") oder .env per Tool laden — Node lädt .env nicht von selbst.
# Ollama vom Host: LLM_PROVIDER=ollama und in server.js/Env ggf. baseURL auf http://127.0.0.1:11434 (eigenes Setup)
